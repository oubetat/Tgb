{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile photo URL" },
        "role": { "type": "string", "enum": ["pioneer", "global", "admin"], "description": "User's role in the system" },
        "piUid": { "type": "string", "description": "Pi Network unique ID for Pioneers" },
        "piWalletAddress": { "type": "string", "description": "Pi Network wallet address (G...)" },
        "kycStatus": { "type": "string", "enum": ["none", "pending", "verified", "rejected"], "description": "KYC status for external users" },
        "firstName": { "type": "string", "description": "User's legal first name" },
        "lastName": { "type": "string", "description": "User's legal last name" },
        "dob": { "type": "string", "description": "User's date of birth" },
        "docType": { "type": "string", "description": "Type of identity document uploaded" },
        "passphrase": { "type": "string", "description": "24-word wallet passphrase" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["uid", "role"]
    },
    "KycDocument": {
      "title": "KYC Document",
      "description": "Metadata for KYC documents uploaded by external users",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User's UID" },
        "documentType": { "type": "string", "enum": ["passport", "id_card", "driver_license"] },
        "documentUrl": { "type": "string", "description": "URL to the document in storage" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "documentType", "documentUrl", "status"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "User's wallet balances",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "pi": { "type": "number", "description": "Pi balance" },
        "usd": { "type": "number", "description": "USD balance" },
        "dzd": { "type": "number", "description": "DZD balance" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["uid", "pi", "usd", "dzd"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique transaction ID" },
        "uid": { "type": "string", "description": "User's UID" },
        "recipientUid": { "type": "string", "description": "Recipient's UID for transfers" },
        "amount": { "type": "number", "description": "Transaction amount" },
        "currency": { "type": "string", "enum": ["pi", "usd", "dzd"], "description": "Transaction currency" },
        "type": { "type": "string", "enum": ["deposit", "withdraw", "transfer", "shop"], "description": "Transaction type" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"], "description": "Transaction status" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the transaction occurred" }
      },
      "required": ["uid", "amount", "currency", "type", "status", "timestamp"]
    },
    "Card": {
      "title": "Virtual Card",
      "description": "A virtual Visa/Mastercard",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "cardNumber": { "type": "string", "description": "Masked card number" },
        "expiry": { "type": "string", "description": "Expiry date MM/YY" },
        "cvv": { "type": "string", "description": "CVV code" },
        "type": { "type": "string", "enum": ["visa", "mastercard"], "description": "Card type" },
        "status": { "type": "string", "enum": ["active", "pending", "blocked"], "description": "Card status" },
        "balance": { "type": "number", "description": "Card specific balance in USD" }
      },
      "required": ["uid", "cardNumber", "expiry", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "A product available in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "integer" }
      },
      "required": ["name", "price", "image"]
    },
    "Loan": {
      "title": "Loan Request",
      "description": "A P2P loan request",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "apr": { "type": "number" },
        "purpose": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "amount", "apr", "status"]
    },
    "InvestmentPool": {
      "title": "Investment Pool",
      "description": "A group investment pool",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "totalInvested": { "type": "number" },
        "target": { "type": "number" },
        "membersCount": { "type": "integer" },
        "image": { "type": "string" }
      },
      "required": ["name", "category", "target"]
    },
    "PiMetric": {
      "title": "Pi Network Metric",
      "description": "Global Pi Network statistics",
      "type": "object",
      "properties": {
        "totalSupply": { "type": "number" },
        "circulatingSupply": { "type": "number" },
        "lockedSupply": { "type": "number" },
        "activeCountries": { "type": "integer" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["totalSupply", "circulatingSupply", "lastUpdated"]
    },
    "Staking": {
      "title": "Staking",
      "description": "User's staked Pi",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "duration": { "type": "integer", "description": "Duration in days" },
        "rewardRate": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "amount", "duration", "rewardRate", "status"]
    },
    "Partnership": {
      "title": "Business Partnership",
      "description": "A business partnership proposal",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "proposalType": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyName", "email", "proposalType", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/wallets/{userId}": {
      "schema": "Wallet",
      "description": "User's wallet data"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction history"
    },
    "/cards/{cardId}": {
      "schema": "Card",
      "description": "Virtual card data"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    },
    "/loans/{loanId}": {
      "schema": "Loan",
      "description": "P2P loans"
    },
    "/pools/{poolId}": {
      "schema": "InvestmentPool",
      "description": "Investment pools"
    },
    "/metrics/global": {
      "schema": "PiMetric",
      "description": "Global Pi metrics"
    },
    "/staking/{stakingId}": {
      "schema": "Staking",
      "description": "Staking records"
    },
    "/partnerships/{partnershipId}": {
      "schema": "Partnership",
      "description": "Partnership proposals"
    }
  }
}
