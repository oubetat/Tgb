{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile photo URL" },
        "role": { "type": "string", "enum": ["pioneer", "global", "admin"], "description": "User's role in the system" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["uid", "email", "role"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "User's wallet balances",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "pi": { "type": "number", "description": "Pi balance" },
        "usd": { "type": "number", "description": "USD balance" },
        "dzd": { "type": "number", "description": "DZD balance" },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["uid", "pi", "usd", "dzd"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique transaction ID" },
        "uid": { "type": "string", "description": "User's UID" },
        "recipientUid": { "type": "string", "description": "Recipient's UID for transfers" },
        "amount": { "type": "number", "description": "Transaction amount" },
        "currency": { "type": "string", "enum": ["pi", "usd", "dzd"], "description": "Transaction currency" },
        "type": { "type": "string", "enum": ["deposit", "withdraw", "transfer", "shop"], "description": "Transaction type" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"], "description": "Transaction status" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the transaction occurred" }
      },
      "required": ["uid", "amount", "currency", "type", "status", "timestamp"]
    },
    "Card": {
      "title": "Virtual Card",
      "description": "A virtual Visa/Mastercard",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner's UID" },
        "cardNumber": { "type": "string", "description": "Masked card number" },
        "expiry": { "type": "string", "description": "Expiry date MM/YY" },
        "cvv": { "type": "string", "description": "CVV code" },
        "type": { "type": "string", "enum": ["visa", "mastercard"], "description": "Card type" },
        "status": { "type": "string", "enum": ["active", "pending", "blocked"], "description": "Card status" },
        "balance": { "type": "number", "description": "Card specific balance in USD" }
      },
      "required": ["uid", "cardNumber", "expiry", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/wallets/{userId}": {
      "schema": "Wallet",
      "description": "User's wallet data"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction history"
    },
    "/cards/{cardId}": {
      "schema": "Card",
      "description": "Virtual card data"
    }
  }
}
