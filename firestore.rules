// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: userId (Auth UID)
// Fields:
//   - uid: string (required) - User's unique ID
//   - email: string (required) - User's email
//   - displayName: string - User's name
//   - role: string (required, ['pioneer', 'global', 'admin']) - User's role
//   - piUid: string - Pi Network unique ID
//   - kycStatus: string (['none', 'pending', 'verified', 'rejected']) - KYC status
//   - createdAt: timestamp - Creation time
//
// Collection: wallets
// Document ID: userId (Auth UID)
// Fields:
//   - uid: string (required) - Owner's UID
//   - pi: number (required) - Pi balance
//   - usd: number (required) - USD balance
//   - dzd: number (required) - DZD balance
//   - lastUpdated: timestamp - Last update time
//
// Collection: transactions
// Document ID: auto-generated
// Fields:
//   - uid: string (required) - User's UID
//   - type: string (required, ['deposit', 'withdraw', 'transfer', 'shop']) - Type
//   - amount: number (required) - Amount
//   - currency: string (required, ['pi', 'usd', 'dzd']) - Currency
//   - description: string - Note
//   - timestamp: timestamp (required) - Time
//   - status: string (required, ['completed', 'pending', 'failed']) - Status
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "oubetat.1@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role']) &&
             data.uid is string &&
             (!('email' in data) || data.email is string) &&
             data.role in ['pioneer', 'global', 'admin'] &&
             (!('kycStatus' in data) || data.kycStatus in ['none', 'pending', 'verified', 'rejected']) &&
             (!('piUid' in data) || data.piUid is string) &&
             (!('piWalletAddress' in data) || data.piWalletAddress is string) &&
             (!('firstName' in data) || data.firstName is string) &&
             (!('lastName' in data) || data.lastName is string) &&
             (!('dob' in data) || data.dob is string) &&
             (!('docType' in data) || data.docType is string) &&
             (!('passphrase' in data) || data.passphrase is string);
    }

    function isValidWallet(data) {
      return data.keys().hasAll(['uid', 'balances']) &&
             data.uid is string &&
             data.balances is map;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['uid', 'type', 'amount', 'currency', 'status', 'timestamp']) &&
             data.uid is string &&
             data.type in ['deposit', 'withdraw', 'transfer', 'shop', 'loan', 'repayment', 'stake', 'unstake'] &&
             data.amount is number &&
             data.currency is string &&
             data.status in ['completed', 'pending', 'failed'];
    }

    function isValidCard(data) {
      return data.keys().hasAll(['uid', 'cardNumber', 'expiry', 'status']) &&
             data.uid is string &&
             data.cardNumber is string &&
             data.expiry is string &&
             data.status in ['active', 'pending', 'blocked'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAdmin() || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role);
    }

    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidWallet(request.resource.data);
      allow update: if isAdmin() || (isOwner(userId) && isValidWallet(request.resource.data)) || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pi']));
    }

    match /transactions/{txId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || request.auth.uid == resource.data.recipientUid || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid && isValidTransaction(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /cards/{cardId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.uid && isValidCard(request.resource.data);
      allow update: if isAdmin() || (isOwner(resource.data.uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
